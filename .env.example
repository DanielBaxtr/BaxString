# App
PORT=3000
APP_BASE_URL=http://localhost:3000

# Payment mode: manual or vipps
PAYMENT_MODE=manual
MANUAL_VIPPS_NUMBER=97908575

# Vipps environment: test or production
VIPPS_ENV=test

# Vipps credentials
VIPPS_CLIENT_ID=your-client-id
VIPPS_CLIENT_SECRET=your-client-secret
VIPPS_SUBSCRIPTION_KEY=your-subscription-key
VIPPS_MSN=your-merchant-serial-number

# Automatically capture authorized payments after return from Vipps
VIPPS_AUTO_CAPTURE=true
